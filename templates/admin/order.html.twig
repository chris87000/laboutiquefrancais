{# templates/admin/my_dashboard.html.twig #}
{% extends '@EasyAdmin/layout.html.twig' %}

{% block main %}
    <h3>Commande n°{{ order.id }}</h3>
    {{ include('admin/states.html.twig', {field: {'value': order.state}}) }}
    <br/>
    <span>Passée le {{ order.createdAt | date('d/m/Y') }}</span>

    <div class="row my-4">
        <div class="col-md-6">
            <strong>Adresse de livraison</strong><br/>
            {{ order.delivery|raw }}
        </div>
        <div class="col-md-6">
            {{ order.carrierName }}
        </div>
    </div>
    <strong>Contenu de la commande</strong><br/>
    <!-- {{  dump(order) }} -->


    <table class="table">
        <thead>
        <tr>
            <th scope="col">Illustration</th>
            <th scope="col">Nom du produit</th>
            <th>Quantité</th>
            <th>Pric unitaire H.T</th>
            <th>TVA</th>
            <th>Total T.T.C</th>
        </tr>
        </thead>
        <tbody>
        {% for product in order.orderDetails %}
            <tr>
                <td>
                    <img src="/uploads/{{product.productIllustration }}" alt="{{ product.productIllustration }}" width="100">
                </td>
                <td>{{ product.productName }}</td>
                <tD>{{ product.productQuantity }}</tD>
                <td>{{ product.productPrice | price }}</td>
                <td>{{ product.productTva }}%</td>
                {%  set coeff = 1 + (product.productTva /100) %}
                <td>{{ (coeff * product.productPrice * product.productQuantity) | price  }}</td>
            </tr>
        {% endfor %}
        <tr>
            <td></td>
            <td>{{ order.carrierName }}</td>
            <td>1</td>
            <td></td>
            <td></td>
            <td>{{ order.carrierPrice | price }}</td>
        </tr>

        </tbody>
    </table>
    <div class="text-center fs-5">
        <strong>Total H.T</strong> {{ (order.TotalWt -  order.TotalTva) | price }}<br/>
        <strong>Total TVA</strong> {{ order.TotalTva | price }}<br/>
        <strong>Total T.T.C</strong> {{ order.TotalWt | price }}
    </div>
{% endblock main %}
